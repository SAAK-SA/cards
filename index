<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SAAK - Employee Card Acknowledgment</title>
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+Arabic:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: 'Noto Sans Arabic', 'Segoe UI', Tahoma, sans-serif;
            background: #eef1f4;
            min-height: 100vh;
            padding: 16px;
            direction: rtl;
        }
        .container { max-width: 480px; margin: 0 auto; }
        .card {
            background: white;
            border-radius: 20px;
            overflow: hidden;
            box-shadow: 0 4px 20px rgba(0,0,0,0.08);
        }
        .card-header {
            padding: 32px 25px 24px;
            text-align: center;
        }
        .card-header img {
            max-width: 175px;
            height: auto;
            display: block;
            margin: 0 auto 20px;
        }
        .header-divider {
            height: 1px;
            background: #e5e7eb;
            margin: 0 0 24px;
        }
        .card-header h1 {
            font-size: 21px;
            font-weight: 700;
            color: #16355f;
            margin-bottom: 6px;
        }
        .card-header .subtitle {
            font-size: 14px;
            color: #8a94a3;
            font-weight: 400;
        }
        .card-body { padding: 0 25px 30px; }
        .form-group { margin-bottom: 20px; }
        .form-group label {
            display: flex;
            justify-content: space-between;
            align-items: baseline;
            margin-bottom: 9px;
        }
        .form-group label .ar {
            color: #16355f;
            font-weight: 600;
            font-size: 16px;
        }
        .form-group label .en {
            color: #8a94a3;
            font-weight: 400;
            font-size: 13px;
        }
        .form-group label .req { color: #04875D; margin-left: 3px; }
        .form-group input[type="text"],
        .form-group input[type="date"] {
            width: 100%;
            padding: 15px 16px;
            border: 1.5px solid #e2e6ea;
            border-radius: 12px;
            font-size: 16px;
            font-family: inherit;
            transition: all 0.2s;
            direction: rtl;
            background: #fafbfc;
            color: #16355f;
        }
        .form-group input:focus {
            outline: none;
            border-color: #04875D;
            background: #f0faf6;
        }
        .photo-upload {
            border: 2px dashed #cdd4db;
            border-radius: 14px;
            padding: 32px 20px;
            text-align: center;
            cursor: pointer;
            background: #fafbfc;
            transition: all 0.2s;
        }
        .photo-upload:hover { background: #f0faf6; border-color: #04875D; }
        .photo-upload-icon { font-size: 40px; margin-bottom: 12px; }
        .photo-upload-text { color: #16355f; font-weight: 600; font-size: 15px; margin-bottom: 4px; }
        .photo-upload-text-en { color: #8a94a3; font-size: 13px; margin-top: 4px; }
        .photo-upload-hint { color: #a3abb5; font-size: 12px; margin-top: 8px; }
        .photo-preview { margin-top: 14px; display: none; }
        .photo-preview img {
            width: 100%;
            max-height: 220px;
            object-fit: cover;
            border-radius: 12px;
            border: 2px solid #04875D;
        }
        .photo-preview .remove-btn {
            display: block;
            text-align: center;
            color: #dc3545;
            font-size: 13px;
            margin-top: 10px;
            cursor: pointer;
            font-weight: 600;
        }
        .ack-box {
            background: #f7f9fb;
            border-radius: 14px;
            padding: 22px 20px;
            border: 1.5px solid #e8ecf0;
            margin: 24px 0;
        }
        .ack-text-ar {
            color: #16355f;
            font-size: 15px;
            line-height: 1.8;
            margin-bottom: 12px;
            text-align: center;
            font-weight: 600;
        }
        .ack-text-en {
            color: #8a94a3;
            font-size: 13px;
            line-height: 1.7;
            margin-bottom: 18px;
            text-align: center;
            font-style: italic;
        }
        .checkbox-wrapper {
            display: flex;
            align-items: center;
            gap: 12px;
            cursor: pointer;
            justify-content: center;
        }
        .checkbox-wrapper input[type="checkbox"] {
            width: 22px;
            height: 22px;
            accent-color: #04875D;
            cursor: pointer;
            flex-shrink: 0;
        }
        .checkbox-labels { text-align: center; cursor: pointer; }
        .checkbox-label-ar { color: #16355f; font-weight: 600; font-size: 15px; display: block; }
        .checkbox-label-en { color: #8a94a3; font-size: 12px; display: block; margin-top: 2px; }
        .submit-btn {
            width: 100%;
            padding: 18px;
            background: #16355f;
            color: white;
            border: none;
            border-radius: 14px;
            font-size: 17px;
            font-weight: 700;
            cursor: pointer;
            transition: all 0.2s;
            font-family: inherit;
        }
        .submit-btn:hover { background: #0f2647; transform: translateY(-1px); }
        .submit-btn:disabled { opacity: 0.6; cursor: not-allowed; transform: none; }
        .submit-btn .en { display: block; font-size: 12px; font-weight: 400; opacity: 0.85; margin-top: 3px; }
        .loading { display: none; text-align: center; padding: 40px 20px; }
        .loading.show { display: block; }
        .spinner {
            display: inline-block; width: 44px; height: 44px;
            border: 4px solid #e5e7eb; border-top: 4px solid #04875D;
            border-radius: 50%; animation: spin 1s linear infinite;
        }
        @keyframes spin { to { transform: rotate(360deg); } }
        .loading-text { color: #8a94a3; font-size: 15px; margin-top: 14px; }
        .loading-text-en { font-size: 12px; margin-top: 4px; opacity: 0.8; }
        .success-page { display: none; text-align: center; padding: 50px 25px; }
        .success-page.show { display: block; }
        .success-icon {
            width: 80px; height: 80px; margin: 0 auto 22px;
            background: linear-gradient(135deg, #16355f 0%, #04875D 100%);
            border-radius: 50%;
            display: flex; align-items: center; justify-content: center;
            font-size: 44px; color: white;
        }
        .success-page h2 { color: #16355f; font-size: 23px; margin-bottom: 6px; }
        .success-page .h2-en { color: #04875D; font-size: 14px; margin-bottom: 20px; }
        .success-page p { color: #16355f; font-size: 15px; margin-bottom: 4px; }
        .success-page .p-en { color: #8a94a3; font-size: 13px; font-style: italic; }
        .error-msg {
            background: #fdeef0; color: #c0392b; padding: 13px 15px;
            border-radius: 10px; font-size: 14px; margin-bottom: 18px;
            display: none; border: 1px solid #f5d0d5; text-align: center;
        }
        .error-msg.show { display: block; }
    </style>
</head>
<body>
    <div class="container">
        <div class="card">
            <div class="card-header">
                <img src="data:image/svg+xml;base64," alt="SAAK International" />
                <div class="header-divider"></div>
                <h1>إقرار استلام بطاقة الموظف</h1>
                <div class="subtitle">Employee Card Acknowledgment</div>
            </div>

            <div class="card-body" id="formSection">
                <div class="error-msg" id="errorMsg"></div>

                <div class="form-group">
                    <label>
                        <span class="ar"><span class="req">*</span> الاسم الثلاثي</span>
                        <span class="en">Full Name</span>
                    </label>
                    <input type="text" id="fullName" required />
                </div>

                <div class="form-group">
                    <label>
                        <span class="ar"><span class="req">*</span> الرقم الوظيفي</span>
                        <span class="en">Employee ID</span>
                    </label>
                    <input type="text" id="employeeId" required />
                </div>

                <div class="form-group">
                    <label>
                        <span class="ar"><span class="req">*</span> تاريخ الاستلام</span>
                        <span class="en">Date of Receipt</span>
                    </label>
                    <input type="date" id="receiptDate" required />
                </div>

                <div class="form-group">
                    <label>
                        <span class="ar"><span class="req">*</span> صورة البطاقة</span>
                        <span class="en">Card Photo</span>
                    </label>
                    <div class="photo-upload" onclick="document.getElementById('photoInput').click()">
                        <div class="photo-upload-icon">📷</div>
                        <div class="photo-upload-text">اضغط لالتقاط صورة البطاقة</div>
                        <div class="photo-upload-text-en">Tap to take a photo of the card</div>
                        <div class="photo-upload-hint">JPG · PNG — الحد الأقصى 5MB</div>
                    </div>
                    <input type="file" id="photoInput" accept="image/*" capture="environment" style="display:none;" onchange="handlePhoto(event)" />
                    <div class="photo-preview" id="photoPreview">
                        <img id="previewImg" />
                        <span class="remove-btn" onclick="removePhoto()">❌ حذف الصورة | Remove Photo</span>
                    </div>
                </div>

                <div class="ack-box">
                    <div class="ack-text-ar">أقر بأنني استلمت بطاقة الموظف الخاصة بي، وأتحمل مسؤولية المحافظة عليها واستخدامها وفق سياسات الشركة.</div>
                    <div class="ack-text-en">I acknowledge that I have received my employee card and I am responsible for maintaining it and using it in accordance with company policies.</div>
                    <div class="checkbox-wrapper" onclick="toggleCheckbox(event)">
                        <input type="checkbox" id="ackCheckbox" />
                        <div class="checkbox-labels">
                            <span class="checkbox-label-ar">أوافق على الإقرار أعلاه</span>
                            <span class="checkbox-label-en">I agree to the above acknowledgment</span>
                        </div>
                    </div>
                </div>

                <button class="submit-btn" id="submitBtn" onclick="submitForm()">
                    تأكيد الاستلام
                    <span class="en">Confirm Receipt</span>
                </button>
            </div>

            <div class="loading" id="loadingSection">
                <div class="spinner"></div>
                <div class="loading-text">
                    جارٍ إرسال البيانات...
                    <div class="loading-text-en">Submitting data...</div>
                </div>
            </div>

            <div class="success-page" id="successSection">
                <div class="success-icon">✓</div>
                <h2>تم تفعيل البطاقة بنجاح!</h2>
                <div class="h2-en">Card activated successfully</div>
                <p>شكراً لك. تم تسجيل إقرار الاستلام.</p>
                <p class="p-en">Thank you. Your acknowledgment has been recorded.</p>
            </div>
        </div>
    </div>

    <script>
        var SCRIPT_URL = "https://script.google.com/macros/s/AKfycbxXU36u5n0thcv0daiDtPx4zGtWjs1GsXXF8bzoMZKbYP-RJQI1a7eh0uTDdyHFraFppQ/exec";
        var photoData = null;
        document.getElementById('receiptDate').valueAsDate = new Date();

        function handlePhoto(event) {
            var file = event.target.files[0];
            if (!file) return;
            if (file.size > 5 * 1024 * 1024) { showError('حجم الصورة كبير | Photo too large (max 5MB)'); return; }
            var reader = new FileReader();
            reader.onload = function(e) {
                photoData = e.target.result;
                document.getElementById('previewImg').src = photoData;
                document.getElementById('photoPreview').style.display = 'block';
            };
            reader.readAsDataURL(file);
        }

        function removePhoto() {
            photoData = null;
            document.getElementById('photoInput').value = '';
            document.getElementById('photoPreview').style.display = 'none';
        }

        function toggleCheckbox(e) {
            if (e.target.tagName === 'INPUT') return;
            document.getElementById('ackCheckbox').checked = !document.getElementById('ackCheckbox').checked;
        }

        function showError(msg) {
            var el = document.getElementById('errorMsg');
            el.textContent = msg;
            el.classList.add('show');
            setTimeout(function() { el.classList.remove('show'); }, 5000);
        }

        function submitForm() {
            var fullName = document.getElementById('fullName').value.trim();
            var employeeId = document.getElementById('employeeId').value.trim();
            var receiptDate = document.getElementById('receiptDate').value;
            var ackChecked = document.getElementById('ackCheckbox').checked;

            if (!fullName) { showError('يرجى إدخال الاسم الثلاثي | Please enter your full name'); return; }
            if (!employeeId) { showError('يرجى إدخال الرقم الوظيفي | Please enter your Employee ID'); return; }
            if (!receiptDate) { showError('يرجى إدخال تاريخ الاستلام | Please enter the date'); return; }
            if (!photoData) { showError('يرجى التقاط صورة للبطاقة | Please take a photo'); return; }
            if (!ackChecked) { showError('يرجى الموافقة على الإقرار | Please agree'); return; }

            document.getElementById('formSection').style.display = 'none';
            document.getElementById('loadingSection').classList.add('show');
            document.getElementById('submitBtn').disabled = true;

            fetch(SCRIPT_URL, {
                method: 'POST',
                mode: 'no-cors',
                headers: { 'Content-Type': 'text/plain' },
                body: JSON.stringify({
                    full_name: fullName,
                    employee_id: employeeId,
                    date: receiptDate,
                    photo: photoData,
                    acknowledged: true
                })
            })
            .then(function() {
                document.getElementById('loadingSection').classList.remove('show');
                document.getElementById('successSection').classList.add('show');
            })
            .catch(function(err) {
                document.getElementById('loadingSection').classList.remove('show');
                document.getElementById('formSection').style.display = 'block';
                document.getElementById('submitBtn').disabled = false;
                showError('حدث خطأ في الإرسال | Submission error');
            });
        }
    </script>
</body>
</html>
